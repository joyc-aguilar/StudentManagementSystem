<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0"
            prefWidth="800.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.studentmanagementsystem.controller.Controller">

    <children>
        <Label layoutX="40.0" layoutY="30.0" text="Student Management System" style="-fx-font-size: 24px; -fx-font-weight: bold;" />

        <Label layoutX="40.0" layoutY="100.0" text="Name:" />
        <TextField fx:id="txtName" layoutX="140.0" layoutY="95.0" prefWidth="220.0" />

        <Label layoutX="40.0" layoutY="150.0" text="Course:" />
        <TextField fx:id="txtCourse" layoutX="140.0" layoutY="145.0" prefWidth="220.0" />

        <Label layoutX="40.0" layoutY="200.0" text="Year Level:" />
        <ChoiceBox fx:id="cbYear" layoutX="140.0" layoutY="195.0" prefWidth="220.0" />

        <Button layoutX="40.0" layoutY="260.0" mnemonicParsing="false" onAction="#addStudent" prefWidth="80.0" text="Add" />
        <Button layoutX="140.0" layoutY="260.0" mnemonicParsing="false" onAction="#updateStudent" prefWidth="80.0" text="Update" />
        <Button layoutX="240.0" layoutY="260.0" mnemonicParsing="false" onAction="#deleteStudent" prefWidth="80.0" text="Delete" />
        <Button layoutX="340.0" layoutY="260.0" mnemonicParsing="false" onAction="#clearFields" prefWidth="80.0" text="Clear" />

        <TableView fx:id="table" layoutX="40.0" layoutY="330.0" prefHeight="220.0" prefWidth="700.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="80.0" text="ID" />
                <TableColumn fx:id="colName" prefWidth="220.0" text="Name" />
                <TableColumn fx:id="colCourse" prefWidth="220.0" text="Course" />
                <TableColumn fx:id="colYear" prefWidth="180.0" text="Year Level" />
            </columns>
        </TableView>
    </children>
</AnchorPane>